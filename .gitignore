# ==========================================
# 1. Environment Variables (환경 변수 - 매우 중요!)
# ==========================================
# 실제 환경변수는 무시하되, 템플릿 파일(.env.example)은 깃허브에 올라가도록 명시적으로 지정합니다.
.env
.env.local
.env.development
.env.test
.env.production
!.env.example

# ==========================================
# 2. Python (Backend & Emulator)
# ==========================================
# 파이썬 실행 시 생성되는 바이트코드 및 캐시 파일
__pycache__/
*.py[cod]
*$py.class

# 파이썬 가상환경 폴더 (용량이 매우 크므로 반드시 제외)
venv/
env/
.venv/
Pipfile.lock

# ==========================================
# 3. Node.js & Next.js (Frontend)
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/coverage
/.next/
/out/
/build

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js TypeScript 관련
*.tsbuildinfo
next-env.d.ts

# ==========================================
# 4. OS, Editor & Misc (운영체제 및 에디터 찌꺼기)
# ==========================================
.DS_Store
Thumbs.db
*.pem
.vercel
.vscode/
.idea/